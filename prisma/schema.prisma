generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Order {
  id             String      @id @default(cuid())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  status         OrderStatus @default(NEW)
  material       String
  color          String
  width          Float
  height         Float
  length         Float
  quantity       Int
  infill         Int
  files          OrderFile[]
  hasModel       Boolean     @default(true)
  comment        String?
  fullName       String
  phone          String
  email          String
  delivery       String
  address        String?
  estimatedPrice Float?
}

model OrderFile {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fileName  String
  fileUrl   String
  fileType  String
  fileSize  Int
  createdAt DateTime @default(now())
}

enum OrderStatus {
  NEW
  IN_PROGRESS
  READY
  DELIVERED
  CANCELLED
}

model PortfolioItem {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String
  material    String
  images      String[]
  params      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  published   Boolean  @default(true)
}

model Material {
  id          String          @id @default(cuid())
  name        String          @unique
  description String
  price       String
  color       String
  best        String
  available   Boolean         @default(true)
  sortOrder   Int             @default(0)
  colors      MaterialColor[]
}

model MaterialColor {
  id         String   @id @default(cuid())
  materialId String
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  name       String
  hex        String
  hex2       String?
  inStock    Boolean  @default(true)
  sortOrder  Int      @default(0)
}

// Better Auth required models
model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}
